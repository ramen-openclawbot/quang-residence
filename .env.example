# ─── Supabase ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — NEVER expose to browser (server-side only)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── OpenAI ─────────────────────────────────────────────────────────────────
# Used for: bank slip OCR (Vision) + daily AI report summary
OPENAI_API_KEY=sk-proj-your-key-here

# ─── App secrets ────────────────────────────────────────────────────────────
# Random secret for admin user-invite API (set same value in Vercel env vars)
ADMIN_SECRET=change-me-to-random-string

# Random secret for Vercel Cron job authentication
CRON_SECRET=change-me-to-random-string

# Public app URL (used in email magic links etc.)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
